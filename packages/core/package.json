{
  "name": "@exclave/boundary",
  "title": "Exclave Boundary",
  "version": "0.3.0-next.0",
  "description": "typed shared-memory boundary substrate for coherent state, deterministic layout, explicit handoff, and timing-sensitive runtimes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/exclave-boundary.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/maikeleckelboom/exclave-boundary#readme",
  "bugs": {
    "url": "https://github.com/maikeleckelboom/exclave-boundary/issues"
  },
  "keywords": [
    "exclave",
    "boundary",
    "typed",
    "sharedarraybuffer",
    "seqlock",
    "shared-memory",
    "deterministic-layout",
    "handoff",
    "typescript",
    "realtime",
    "timing-sensitive"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js",
      "default": "./dist/diagnostics.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "bench": "vitest bench --reporter=verbose --run",
    "bench:format": "tsx scripts/format-bench.ts --clean",
    "bench:report": "pnpm run bench && pnpm run bench:format",
    "lint": "eslint src tests bench scripts",
    "lint:fix": "eslint src tests bench scripts --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "clean": "rimraf dist .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:types": "tsc -b --noEmit --pretty",
    "build": "pnpm run clean && vite build && rollup -c rollup.dts.config.mts",
    "test:pack": "tsx scripts/pack-smoke.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  }
}
