{
  "name": "@seqlok/core",
  "version": "0.0.1",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:cov": "vitest run --coverage",
    "lint": "eslint src --fix",
    "clean": "rimraf .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "test:types": "tsc -b --noEmit --pretty"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "@types/node": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:"
  }
}
