{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["vitest/globals", "node"],
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "examples/**/*",
    "vitest.config.*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
