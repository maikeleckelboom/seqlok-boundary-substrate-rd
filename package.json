{
  "name": "seqlok-boundary-substrate-rd",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "fast-check": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "clean": "pnpm -w -r -F \"@seqlok/core\" -F \"@seqlok/docs\" run clean && rimraf .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "clean:cache": "rimraf node_modules/.vite node_modules/.cache packages/*/node_modules/.vite packages/*/node_modules/.cache apps/*/node_modules/.vite apps/*/node_modules/.cache",
    "clean:caches": "pnpm run clean:cache",
    "purge": "pnpm run clean && rimraf node_modules packages/**/node_modules",
    "build": "pnpm -w run clean && pnpm -w -r -F \"@seqlok/core\" run build",
    "test": "pnpm -w -F \"@seqlok/core\" run test",
    "bench": "pnpm -w -F \"@seqlok/core\" run bench",
    "bench:report": "pnpm -w -F \"@seqlok/core\" run bench:report",
    "test:types": "pnpm -w -F \"@seqlok/core\" run test:types",
    "test:watch": "pnpm run test --watch",
    "test:cov": "pnpm -w -F \"@seqlok/core\" run test:cov",
    "test:pack": "pnpm -w -F \"@seqlok/core\" run test:pack",
    "commitlint": "commitlint --color",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint": "pnpm -w -r -F \"@seqlok/core\" -F \"@seqlok/docs\" run lint",
    "lint:fix": "pnpm -w -r -F \"@seqlok/core\" -F \"@seqlok/docs\" run lint:fix",
    "lint:all": "pnpm lint && pnpm lint:md",
    "format": "prettier --ignore-path .prettierignore --write .",
    "docs:dev": "pnpm -F @seqlok/docs run docs:dev",
    "docs:build": "pnpm -F @seqlok/docs run docs:build",
    "docs:preview": "pnpm -F @seqlok/docs run docs:preview",
    "support": "node scripts/support/seqlok-support.ts",
    "verify": "pnpm clean && pnpm build && pnpm lint && pnpm test:types && pnpm test && pnpm docs:build && pnpm test:pack && pnpm support --json"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "packageManager": "pnpm@11.6.0"
}
