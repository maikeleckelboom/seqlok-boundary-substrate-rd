{
  "name": "seqlok",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "concurrently": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "happy-dom": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "concurrently -n types,core \"pnpm dev:types\" \"pnpm -F @seqlok/core run dev\"",
    "dev:ui": "concurrently -n types,core,app \"pnpm dev:types\" \"pnpm -F @seqlok/core run dev\" \"pnpm -F @seqlok/playground run dev\"",
    "dev:types": "tsc -p tsconfig.workspace.json --noEmit --watch",
    "build": "pnpm -r -F \"@seqlok/*\" run build && tsx scripts/strip-extra-dts.ts",
    "build:runtime": "pnpm -r -F \"@seqlok/*\" -F \"!@seqlok/introspect\" -F \"!@seqlok/integration\" -F \"!@seqlok/playground\" run build",
    "test": "pnpm -r -F \"@seqlok/*\" run test",
    "test:core": "pnpm -F @seqlok/core run test",
    "test:cov": "pnpm -F @seqlok/core run test:cov",
    "test:watch": "pnpm -F @seqlok/core run test:watch",
    "test:types": "tsc -p tsconfig.workspace.json --noEmit",
    "bench": "pnpm -F @seqlok/core run bench",
    "bench:report": "pnpm -F @seqlok/core run bench:report",
    "lint": "pnpm -r -F \"@seqlok/*\" run lint",
    "lint:fix": "pnpm -r -F \"@seqlok/*\" run lint:fix",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --ignore-path .prettierignore --write .",
    "clean": "pnpm -r -F \"@seqlok/*\" run clean && rimraf .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules packages/**/node_modules",
    "commitlint": "commitlint --color",
    "tla:fetch": "tsx scripts/tla/fetch-tools.ts",
    "tla:hotswap": "tsx scripts/tla/run-hotswap.ts invonly",
    "tla:hotswap:full": "tsx scripts/tla/run-hotswap.ts full -nowarning",
    "schema:errors:json": "pnpm -F @seqlok/introspect schema:errors:json",
    "schema:errors:snapshots": "pnpm -F @seqlok/introspect run schema:errors:full && pnpm -F @seqlok/introspect run schema:errors:boundary-safe && pnpm -F @seqlok/introspect run schema:errors:fatal-core"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "packageManager": "pnpm@10.24.0"
}
